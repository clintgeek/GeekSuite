# Example environment file for BaseGeek / DataGeek stack
# Copy to `.env`, `.env.local`, or `.env.production` and adjust per environment.

# Application Ports
PORT=8987
UI_PORT=8988

# JWT Secrets (replace with secure values before running anything)
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# Node Environment
NODE_ENV=development

# MongoDB Connection Details
MONGO_INITDB_ROOT_USERNAME=datageek_admin
MONGO_INITDB_ROOT_PASSWORD=REDACTED
MONGODB_URI=mongodb://datageek_admin:REDACTED@localhost:27018
USERGEEK_MONGODB_URI=mongodb://datageek_admin:REDACTED@localhost:27018/userGeek?authSource=admin
AIGEEK_MONGODB_URI=mongodb://datageek_admin:REDACTED@localhost:27018/aiGeek?authSource=admin

# Redis Connection
REDIS_URI=redis://localhost:6380

# PostgreSQL Connection Details
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_USER=datageek_pg_admin
POSTGRES_PASSWORD=REDACTED
POSTGRES_DB=datageek
POSTGRES_URL=postgres://datageek_pg_admin:REDACTED@localhost:55432/datageek

# InfluxDB Connection Details
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=basegeek
INFLUXDB_BUCKET=datageek_metrics
INFLUXDB_TOKEN=replace_with_scoped_token
INFLUXDB_SETUP_USERNAME=datageek_influx_admin
INFLUXDB_SETUP_PASSWORD=REDACTED
INFLUXDB_ADMIN_TOKEN=replace_with_bootstrap_token
